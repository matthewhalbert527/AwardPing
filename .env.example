NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated login emails allowed to view /dashboard/admin.
AWARDPING_ADMIN_EMAILS=

RESEND_API_KEY=
ALERT_FROM_EMAIL=AwardPing <alerts@example.com>

CRON_SECRET=replace-with-a-long-random-secret
APP_DATA_ENCRYPTION_KEY=replace-with-a-32-byte-random-base64url-secret

TAVILY_API_KEY=
AI_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_DISCOVERY_MODEL=gemini-2.5-flash-lite
GEMINI_SUMMARY_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_DISCOVERY_MODEL=gpt-4.1-mini
OPENAI_SUMMARY_MODEL=gpt-4.1-mini

# Private beta cost controls for /api/awards/discover.
DISCOVERY_DAILY_USER_LIMIT=10
DISCOVERY_DAILY_IP_LIMIT=30
DISCOVERY_DAILY_GLOBAL_LIMIT=100

# Local PC worker controls for shared source crawling.
LOCAL_WORKER_PAGE_LIMIT=25
LOCAL_WORKER_MAX_SUBPAGES_PER_SOURCE=6
LOCAL_WORKER_STRUCTURE_RESCAN_DAYS=7
LOCAL_WORKER_BASELINE_REFRESH=false
LOCAL_WORKER_BASELINE_STARTED_AT=
LOCAL_WORKER_AI_SUMMARIES=true
LOCAL_WORKER_AI_PROVIDER=auto

# Local visual worker Gemini CLI guardrails. By default AwardPing only allows
# the low Flash CLI label below; Pro/High/Thinking models require an explicit override.
AWARDPING_GEMINI_CLI_PATH=
AWARDPING_GEMINI_CLI_MODEL=Gemini 3.5 Flash (Low)
AWARDPING_GEMINI_CLI_MAX_CALLS=100
AWARDPING_AWARD_DETAIL_GEMINI_CLI_MODEL=Gemini 3.5 Flash (Low)
AWARDPING_AWARD_DETAIL_GEMINI_CLI_MAX_CALLS=150
AWARDPING_SAFE_GEMINI_CLI_MODELS=Gemini 3.5 Flash (Low)
AWARDPING_ALLOW_UNSAFE_GEMINI_CLI_MODEL=false
