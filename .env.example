# Hosted application identity
NEXT_PUBLIC_APP_URL=https://awardping.com
NEXT_PUBLIC_SUPABASE_URL=
# Compatibility variable names are retained by the current app and worker.
# Production values must be the new key types shown; legacy JWT keys are blocked.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_with_production_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_with_server_only_key

# Invitation-only administration and email
AWARDPING_ADMIN_EMAILS=
RESEND_API_KEY=
ALERT_FROM_EMAIL=AwardPing <alerts@example.com>
CONTACT_TO_EMAIL=
CRON_SECRET=replace-with-a-long-random-production-secret
APP_DATA_ENCRYPTION_KEY=replace-with-a-32-byte-random-base64url-secret
FREE_CHECK_HOURLY_IP_LIMIT=12

# Exactly two paid pipelines use this key: new_page_review and
# changed_page_review. PostgreSQL atomically fixes each lane at $5 per UTC day.
# The production worker model is pinned in code to gemini-2.5-flash-lite.
GEMINI_API_KEY=

# Immutable screenshot and document evidence
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=awardping-snapshots
R2_SIGNED_URL_TTL_SECONDS=900
AWARDPING_R2_SNAPSHOT_SYNC=true
AWARDPING_R2_OPERATION_RETRIES=3
AWARDPING_R2_REPAIR_MISSING_SNAPSHOTS=true
AWARDPING_VISUAL_SNAPSHOT_DIR=D:\AwardPingVisualSnapshots

# Permanent local worker controls
AWARDPING_VISUAL_WEB_CONCURRENCY=4
LOCAL_WORKER_PAGE_LIMIT=25
LOCAL_WORKER_MAX_SUBPAGES_PER_SOURCE=6
LOCAL_WORKER_STRUCTURE_RESCAN_DAYS=7

# Isolated Stage 1 release-evidence runner only. Do not place the HMAC secret
# in browser code. The matching key and exact production target are provisioned
# separately by direct database administration and Supabase Vault.
AWARDPING_STAGE1_RELEASE_EVIDENCE_HMAC_SECRET=
VERCEL_TOKEN=
VERCEL_CLI_PATH=vercel
AWARDPING_STAGE1_ROLLBACK_DEPLOYMENT=
AWARDPING_STAGE1_RESTORE_DEPLOYMENT=
